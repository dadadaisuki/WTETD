VITE_SUPABASE_URL=https://pjgixbywuffzovsblyku.supabase.co/rest/v1
VITE_SUPABASE_ANON_KEY=replace_with_your_supabase_anon_public_key

# 推荐：前端只调用代理，不把美团密钥暴露在浏览器。
VITE_MEITUAN_PROXY_URL=https://pjgixbywuffzovsblyku.supabase.co/functions/v1/meituan-nearby-ranking
VITE_MEITUAN_API_KEY=

# 兼容：如果你已有自己的公开后端榜单接口，也可以填这里。
VITE_MEITUAN_RANKING_API_URL=

# Supabase Edge Function secrets，不要写进前端 .env.local。
# supabase secrets set MEITUAN_ACCESS_KEY=xxx
# supabase secrets set MEITUAN_ENT_ID=xxx
# supabase secrets set MEITUAN_SECRET_KEY=xxx
# supabase secrets set MEITUAN_API_HOST=https://api-open-cater.meituan.com
# supabase secrets set MEITUAN_API_VERSION=1.0
